[merge]
	tool = kdiff3
	conflictstyle = diff3
	guitool = kdiff3
[mergetool "kdiff3"]
	trustExitCode = false
[diff]
	guitool = kdiff3
[difftool "kdiff3"]
	trustExitCode = false
[core]
	excludesfile = ~/.gitignore_global
	pager = less -+$LESS -RSX
	symlinks = true
	# editor = code --wait --new-window --disable-extensions
[alias]
	st = status
	ci = commit
	cia = commit -a
	co = checkout
	sw = switch
	swc = switch --create
	swm = switch master
	swfm = switch -f master
	di = diff --color
	unstage = reset HEAD
	me = merge --no-ff
	lg = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit --date=relative
	force-push = push --force-with-lease
	pull-master = fetch origin master:master
	fp = push --force-with-lease
	push-new-branch = push --set-upstream origin HEAD
	pnb = push --set-upstream origin HEAD
	pm = fetch origin master:master
	pn = fetch origin main:main
	rema = rebase master
	reima = rebase -i master
	rei = rebase -i
	rec = rebase --continue
	cb = branch --show-current
	fa = fetch --all
[color]
	ui = true
[push]
	default = simple
[commit]
	cleanup = scissors
	gpgsign = true
[pull]
	rebase = false
[fetch]
	prune = false
[rebase]
	autoStash = false
	autosquash = true
[include]
	path = ~/.gitconfig_user_static
	path = ~/.gitconfig_override_gpg
